{
  "openapi": "3.1.0",
  "info": {
    "title": "EduTube API",
    "description": "REST API for EduTube — learning journeys, chapters, notes, and chatbot.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "https://focus-learn-api.vercel.app/api/v1", "description": "Production" },
    { "url": "http://localhost:5000/api/v1", "description": "Local" }
  ],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/users/register": {
      "post": {
        "tags": ["Users"],
        "summary": "Register",
        "description": "Register a new user. Returns user id.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserRegister" }
            }
          }
        },
        "responses": {
          "200": { "description": "User created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserCreateResponse" } } } },
          "400": { "description": "Email already in use" }
        }
      }
    },
    "/users/login": {
      "post": {
        "tags": ["Users"],
        "summary": "Login",
        "description": "Login with email and password. Returns JWT token.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserLogin" }
            }
          }
        },
        "responses": {
          "200": { "description": "Token", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TokenResponse" } } } },
          "400": { "description": "Invalid credentials" }
        }
      }
    },
    "/users/profile": {
      "get": {
        "tags": ["Users"],
        "summary": "Get profile",
        "description": "Return current user profile. Requires Bearer token."
      }
    },
    "/journeys": {
      "get": {
        "tags": ["Journeys"],
        "summary": "List journeys",
        "description": "List all journeys for the authenticated user."
      },
      "post": {
        "tags": ["Journeys"],
        "summary": "Create journey",
        "description": "Create a new journey (title, description, is_public)."
      }
    },
    "/journeys/public": {
      "get": {
        "tags": ["Journeys"],
        "summary": "List public journeys",
        "description": "List all public journeys. Requires auth."
      }
    },
    "/journeys/playlist": {
      "post": {
        "tags": ["Journeys"],
        "summary": "Create from playlist",
        "description": "Create journey from YouTube playlist ID. Imports videos as chapters."
      }
    },
    "/journeys/{journey_id}": {
      "get": {
        "tags": ["Journeys"],
        "summary": "Get journey",
        "parameters": [{ "name": "journey_id", "in": "path", "required": true, "schema": { "type": "string" } }]
      },
      "put": {
        "tags": ["Journeys"],
        "summary": "Update journey"
      },
      "delete": {
        "tags": ["Journeys"],
        "summary": "Delete journey"
      }
    },
    "/journeys/{journey_id}/fork": {
      "post": {
        "tags": ["Journeys"],
        "summary": "Fork journey",
        "description": "Copy a public journey to the current user."
      }
    },
    "/journeys/{journey_id}/chapters": {
      "get": {
        "tags": ["Chapters"],
        "summary": "List chapters",
        "description": "Get all chapters for a journey."
      },
      "post": {
        "tags": ["Chapters"],
        "summary": "Create chapter",
        "description": "Add a new chapter (title, description, video_link, chapter_no)."
      }
    },
    "/journeys/chapters/{chapter_id}": {
      "get": { "tags": ["Chapters"], "summary": "Get chapter" },
      "put": { "tags": ["Chapters"], "summary": "Update chapter" },
      "delete": { "tags": ["Chapters"], "summary": "Delete chapter" }
    },
    "/journeys/chapters/isComplete/{chapter_id}": {
      "put": {
        "tags": ["Chapters"],
        "summary": "Mark chapter complete",
        "description": "Set is_completed for a chapter."
      }
    },
    "/journeys/{journey_id}/chapters/{chapter_id}/notes": {
      "post": {
        "tags": ["Notes"],
        "summary": "Create note"
      }
    },
    "/chapters/{chapter_id}/notes": {
      "get": { "tags": ["Notes"], "summary": "List notes by chapter" }
    },
    "/journeys/{journey_id}/notes": {
      "get": { "tags": ["Notes"], "summary": "List notes by journey" }
    },
    "/notes/{note_id}": {
      "get": { "tags": ["Notes"], "summary": "Get note" },
      "put": { "tags": ["Notes"], "summary": "Update note" },
      "delete": { "tags": ["Notes"], "summary": "Delete note" }
    },
    "/chatbot/chat": {
      "post": {
        "tags": ["Chatbot"],
        "summary": "Chat",
        "description": "Send a message to the AI chatbot.",
        "security": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": { "type": "string" },
                  "context": { "type": "string" },
                  "use_knowledge": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    },
    "/chatbot/health": {
      "get": {
        "tags": ["Chatbot"],
        "summary": "Health check",
        "security": []
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "UserRegister": {
        "type": "object",
        "required": ["username", "email", "password"],
        "properties": {
          "username": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        }
      },
      "UserLogin": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        }
      },
      "UserCreateResponse": { "type": "object", "properties": { "id": { "type": "string" } } },
      "TokenResponse": { "type": "object", "properties": { "token": { "type": "string" } } }
    }
  }
}
